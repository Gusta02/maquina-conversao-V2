# ── Groq (LLM) ────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ElevenLabs (TTS) ──────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Pexels (B-Roll) ───────────────────────────────────────────────────────────
PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Drive ──────────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
GOOGLE_DRIVE_FOLDER_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── App Settings ──────────────────────────────────────────────────────────────
TTS_PROVIDER=elevenlabs          # elevenlabs | edge_tts | google_cloud
WHISPER_MODEL=base               # tiny | base | small | medium
VIDEO_CRF=23                     # 18=best quality, 28=smaller file
LOG_LEVEL=INFO
